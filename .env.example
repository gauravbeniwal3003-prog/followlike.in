# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Frontend Config
# If deploying frontend separately (e.g. Cloudflare Workers), point this to your Render backend URL (e.g. https://your-backend.onrender.com). Leave empty if hosting as a full-stack monolithic app.
VITE_API_BASE_URL=

# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMM Panel Integration
SMM_API_KEY=YOUR_SMM_API_KEY_HERE
SMM_API_URL=https://socialuphub-backend.onrender.com/api/v2

# Supabase Configuration
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
